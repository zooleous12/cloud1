{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session between the user and Gemini.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "An individual message within a chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    },
    "AnalysisResult": {
      "title": "Analysis Result",
      "description": "Result of an image or video analysis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "mediaUrl": { "type": "string" },
        "analysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "analysis", "createdAt"]
    },
    "GeneratedImage": {
      "title": "Generated Image",
      "description": "Information about an image generated by Gemini.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "size": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat session metadata."
    },
    "chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages across all chat sessions."
    },
    "analysisResults/{analysisId}": {
      "schema": "AnalysisResult",
      "description": "Image and video analysis results."
    },
    "generatedImages/{imageId}": {
      "schema": "GeneratedImage",
      "description": "History of generated images."
    }
  }
}
